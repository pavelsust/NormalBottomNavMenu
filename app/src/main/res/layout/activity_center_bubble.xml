<?xml version="1.0" encoding="utf-8"?>
<!--
  clipChildren/clipToPadding = false on the root lets the BubbleTabBar's
  floating centre circle render above the bar without being clipped.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/bubbleNavHost"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:navGraph="@navigation/bubble_nav_graph"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bubbleTabBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <io.ak1.CenterCircleTabBar
        android:id="@+id/bubbleTabBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@color/white"
        android:clipChildren="false"
        android:elevation="8dp"
        app:bubbletab_custom_font="@font/manrope_medium"
        app:bubbletab_horizontal_padding="@dimen/_17sdp"
        app:bubbletab_icon_size="@dimen/_10sdp"
        app:bubbletab_title_size="@dimen/_20sdp"
        app:bubbletab_icon_padding="@dimen/_2sdp"
        app:bubbletab_vertical_padding="@dimen/_7sdp"
        app:bubbletab_tab_corner_radius="@dimen/_25sdp"
        app:bubbletab_bar_height="56dp"
        app:bubbletab_center_item_size="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
