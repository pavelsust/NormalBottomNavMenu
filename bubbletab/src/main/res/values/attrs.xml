<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="BubbleTabBar">
        <attr name="bubbletab_menuResource" format="reference" />

        <!-- bar -->
        <attr name="bubbletab_bar_height" format="dimension" />
        <attr name="bubbletab_bar_background_color" format="color" />

        <!-- side tabs -->
        <attr name="bubbletab_disabled_icon_color" format="color" />
        <attr name="bubbletab_title_disable_color" format="color" />
        <attr name="bubbletab_custom_font" format="reference" />
        <attr name="bubbletab_horizontal_padding" format="dimension" />
        <attr name="bubbletab_vertical_padding" format="dimension" />
        <attr name="bubbletab_icon_padding" format="dimension" />
        <attr name="bubbletab_icon_size" format="dimension" />
        <attr name="bubbletab_title_size" format="dimension" />
        <attr name="bubbletab_tab_corner_radius" format="dimension" />
        <attr name="bubbletab_title_top_padding" format="dimension" />

        <!-- centre FAB -->
        <attr name="bubbletab_center_item_size" format="dimension" />
        <attr name="bubbletab_center_item_elevation" format="dimension" />
        <attr name="bubbletab_center_icon_color" format="color" />
    </declare-styleable>

    <!-- Per-menu-item attributes parsed by MenuParser -->
    <declare-styleable name="Bubble">
        <attr name="android:id" />
        <attr name="android:title" />
        <attr name="android:icon" />
        <attr name="android:enabled" />
        <attr name="android:checked" />
        <attr name="android:color" />
    </declare-styleable>

</resources>